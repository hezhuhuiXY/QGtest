<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.system.mapper.AdminMapper">
    <insert id="insertAdmin" useGeneratedKeys="true" keyProperty="id">
        insert into admin_user(admin_id,password)
        values(#{adminId},#{password});
    </insert>


    <select id="selectByUsername" resultType="com.system.pojo.Admin">
        select * from admin_user;
    </select>
    <select id="selectByadminId" resultType="com.system.pojo.Admin">
        select * from admin_user;
    </select>


</mapper>